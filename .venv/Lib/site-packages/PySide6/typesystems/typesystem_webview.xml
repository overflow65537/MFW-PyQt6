<typesystem package="PySide6.QtWebView"
            namespace-begin="QT_BEGIN_NAMESPACE" namespace-end="QT_END_NAMESPACE">
    <load-typesystem name="typesystem_gui.xml" generate ="no"/>
    <namespace-type name="QtWebView"/>
    <object-type name="QWebView" since="6.11">
        <extra-includes>
            <include file-name="autodecref.h" location="global"/>
            <include file-name="gilstate.h" location="global"/>
            <include file-name="pyobjectholder.h" location="global"/>
            <include file-name="pysidevariantutils.h" location="global"/>
            <include file-name="functional" location="global"/>
        </extra-includes>
        <inject-code class="native" position="beginning" file="../glue/qtwebview.cpp"
                     snippet="qwebview-runjavascriptfunctor"/>
        <modify-function signature="^runJavaScript\(.*\)$" remove="yes"/>
        <add-function signature="runJavaScript(const QString &amp;@scriptSource@,PyCallable*@resultCallback@)">
            <inject-code class="target" position="beginning" file="../glue/qtwebview.cpp"
                         snippet="qwebview-runjavascript"/>
        </add-function>
    </object-type>
    <value-type name="QWebViewLoadingInfo" since="6.11">
        <enum-type name="LoadStatus"/>
    </value-type>
    <object-type name="QWebViewSettings" since="6.11">
        <enum-type name="WebAttribute"/>
    </object-type>
</typesystem>
